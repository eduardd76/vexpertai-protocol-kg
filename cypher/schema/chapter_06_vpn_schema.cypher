CREATE INDEX ipsec_crypto_state IF NOT EXISTS FOR (n:IPsecTunnel) ON (n.crypto_state);
CREATE INDEX tunnel_health_status IF NOT EXISTS FOR (n:TunnelHealth) ON (n.status);
CREATE INDEX vpn_sla_status IF NOT EXISTS FOR (n:VPNSLA) ON (n.status);
CREATE INDEX ike_state_value IF NOT EXISTS FOR (n:IKEState) ON (n.state);
CREATE INDEX routing_state_value IF NOT EXISTS FOR (n:RoutingState) ON (n.state);
