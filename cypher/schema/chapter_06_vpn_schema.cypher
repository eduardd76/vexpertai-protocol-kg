CREATE CONSTRAINT vpn_spoke_id IF NOT EXISTS FOR (n:Spoke) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT overlay_tunnel_id IF NOT EXISTS FOR (n:OverlayTunnel) REQUIRE n.id IS UNIQUE;
