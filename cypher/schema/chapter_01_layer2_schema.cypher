CREATE CONSTRAINT l2_virtual_ip_id IF NOT EXISTS FOR (n:VirtualIP) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT l2_virtual_mac_id IF NOT EXISTS FOR (n:VirtualMAC) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT l2_default_gateway_id IF NOT EXISTS FOR (n:DefaultGateway) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT l2_fhrp_active_gateway_id IF NOT EXISTS FOR (n:FHRPActiveGateway) REQUIRE n.id IS UNIQUE;
