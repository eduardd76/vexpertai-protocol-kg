CREATE INDEX l2_vlan_number IF NOT EXISTS FOR (n:VLAN) ON (n.vlan_id);
CREATE INDEX l2_access_port_status IF NOT EXISTS FOR (n:AccessPort) ON (n.status);
CREATE INDEX l2_trunk_unused_vlans IF NOT EXISTS FOR (n:Trunk) ON (n.unused_vlan_count);
CREATE INDEX l2_risk_severity IF NOT EXISTS FOR (n:Layer2Risk) ON (n.severity);
