CREATE CONSTRAINT l2_loop_guard_id IF NOT EXISTS FOR (n:LoopGuard) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT l2_bpdu_guard_id IF NOT EXISTS FOR (n:BPDUGuard) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT l2_bpdu_filter_id IF NOT EXISTS FOR (n:BPDUFilter) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT l2_vtp_domain_id IF NOT EXISTS FOR (n:VTPDomain) REQUIRE n.id IS UNIQUE;
