CREATE CONSTRAINT qos_wan_link_id IF NOT EXISTS FOR (n:WANLink) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_oversubscription_risk_id IF NOT EXISTS FOR (n:OversubscriptionRisk) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_queue_id IF NOT EXISTS FOR (n:Queue) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_sla_objective_id IF NOT EXISTS FOR (n:SLAObjective) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_congestion_point_id IF NOT EXISTS FOR (n:CongestionPoint) REQUIRE n.id IS UNIQUE;
