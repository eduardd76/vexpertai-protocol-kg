CREATE CONSTRAINT qos_design_assessment_id IF NOT EXISTS FOR (n:QoSDesignAssessment) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_risk_id IF NOT EXISTS FOR (n:QoSRisk) REQUIRE n.id IS UNIQUE;

CREATE INDEX qos_policy_status IF NOT EXISTS FOR (n:QoSPolicy) ON (n.status);
CREATE INDEX qos_dscp_value IF NOT EXISTS FOR (n:DSCP) ON (n.value);
CREATE INDEX qos_congestion_severity IF NOT EXISTS FOR (n:CongestionEvent) ON (n.severity);
CREATE INDEX qos_queue_utilization IF NOT EXISTS FOR (n:InterfaceQueue) ON (n.utilization_percent);
CREATE INDEX qos_wan_peak_utilization IF NOT EXISTS FOR (n:WANLink) ON (n.peak_utilization_percent);
CREATE INDEX qos_sla_metric IF NOT EXISTS FOR (n:SLARequirement) ON (n.metric);
CREATE INDEX qos_risk_severity IF NOT EXISTS FOR (n:QoSRisk) ON (n.severity);
