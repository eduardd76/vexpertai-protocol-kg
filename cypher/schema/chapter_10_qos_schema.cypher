CREATE CONSTRAINT qos_policy_id_v2 IF NOT EXISTS FOR (n:QoSPolicy) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_class_map_id IF NOT EXISTS FOR (n:ClassMap) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_policy_map_id IF NOT EXISTS FOR (n:PolicyMap) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_class_id IF NOT EXISTS FOR (n:QoSClass) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_traffic_class_id_v2 IF NOT EXISTS FOR (n:TrafficClass) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_dscp_id IF NOT EXISTS FOR (n:DSCP) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_cos_id IF NOT EXISTS FOR (n:CoS) REQUIRE n.id IS UNIQUE;
