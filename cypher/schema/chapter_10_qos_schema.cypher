CREATE CONSTRAINT qos_policing_policy_id IF NOT EXISTS FOR (n:PolicingPolicy) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_shaping_policy_id IF NOT EXISTS FOR (n:ShapingPolicy) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_queuing_policy_id IF NOT EXISTS FOR (n:QueuingPolicy) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_priority_queue_id IF NOT EXISTS FOR (n:PriorityQueue) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_bandwidth_guarantee_id IF NOT EXISTS FOR (n:BandwidthGuarantee) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_wred_id IF NOT EXISTS FOR (n:WRED) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_congestion_event_id IF NOT EXISTS FOR (n:CongestionEvent) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_interface_queue_id IF NOT EXISTS FOR (n:InterfaceQueue) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_application_traffic_id IF NOT EXISTS FOR (n:ApplicationTraffic) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_voice_traffic_id IF NOT EXISTS FOR (n:VoiceTraffic) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_video_traffic_id IF NOT EXISTS FOR (n:VideoTraffic) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_critical_data_traffic_id IF NOT EXISTS FOR (n:CriticalDataTraffic) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_best_effort_traffic_id IF NOT EXISTS FOR (n:BestEffortTraffic) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_sla_requirement_id IF NOT EXISTS FOR (n:SLARequirement) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_latency_requirement_id IF NOT EXISTS FOR (n:LatencyRequirement) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT qos_jitter_requirement_id IF NOT EXISTS FOR (n:JitterRequirement) REQUIRE n.id IS UNIQUE;
